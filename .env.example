# ─────────────────────────────────────────────
# Agentes Monorepo — variables compartidas
# Copiar a .env. NUNCA commitear .env.
#
# Cada módulo con service/ tiene además su propio .env (en {modulo}/service/.env).
# Las variables de acá se cargan automáticamente como fallback.
# ─────────────────────────────────────────────

# ── Anthropic (compartido) ───────────────────
ANTHROPIC_API_KEY=
# Local: claude-haiku-4-5 (barato/rápido). Prod: deploy.sh lo sobrescribe a sonnet.
CLAUDE_MODEL=claude-haiku-4-5

# ── Logging ──────────────────────────────────
LOG_LEVEL=INFO

# ── Notion (si se usa shared/notion_client) ──
# NOTION_TOKEN=
# NOTION_LEARNINGS_DB=
# NOTION_ACTIONS_DB=

# ── Cloud (sólo el que uses) ─────────────────
# Azure Container Apps
# AZURE_RESOURCE_GROUP=
# AZURE_LOCATION=
# AZURE_CONTAINERAPPS_ENV=

# AWS App Runner / ECS
# AWS_REGION=
# AWS_ACCOUNT_ID=

# Google Cloud Run
# GCP_PROJECT=
# GCP_REGION=

# ── Container Registry ───────────────────────
REGISTRY_PREFIX=docker.io/dev3ch
# DOCKERHUB_USERNAME=
# DOCKERHUB_TOKEN=
